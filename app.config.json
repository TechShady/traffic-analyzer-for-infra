{
  "$schema": "./.dt-app/app.config.schema.json",
  "environmentUrl": "https://guu84124.apps.dynatrace.com/",
  "app": {
    "name": "Traffic Analyzer for Infrastructure",
    "version": "0.15.1",
    "description": "Infrastructure traffic analysis with forecasting and Pearson Correlation",
    "id": "my.traffic.analyzer.infra.app",
    "scopes": [
      { "name": "storage:logs:read", "comment": "default template" },
      { "name": "storage:buckets:read", "comment": "default template" },
      { "name": "storage:metrics:read", "comment": "read host metrics" },
      { "name": "storage:entities:read", "comment": "read host entities" },
      { "name": "environment-api:metrics:read", "comment": "read metrics v2" },
      { "name": "storage:events:read", "comment": "read events" },
      { "name": "storage:system:read", "comment": "read system data" },
      { "name": "environment-api:entities:read", "comment": "read entities v2" }
    ]
  }
}