        "content": "## 📊 System Health at a Glance"
      },
      "3": {
        "type": "data",
        "title": "System Uptime",
        "query": "data record(value = 99.97)\n| fields `System Uptime (%)` = value",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "recordField": "System Uptime (%)",
            "labelMode": "none"
          },
          "coloring": {
            "colorRules": [
              {
                "value": 99,
                "comparator": ">=",
                "field": "System Uptime (%)",
                "colorMode": "custom-color",
                "customColor": "#1DBB53"
              }
            ]
          },
          "autoSelectVisualization": false
        },
        "querySettings": {},
